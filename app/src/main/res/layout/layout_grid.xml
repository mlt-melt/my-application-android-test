<?xml version="1.0" encoding="utf-8"?>
<!--
GridLayout - табличная сетка с гибким позиционированием
Атрибуты: rowCount, columnCount, layout_row, layout_column, 
layout_rowSpan, layout_columnSpan
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp"
    tools:context=".MainActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Заголовок -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📦 GridLayout: Прямоугольная сетка"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:padding="12dp"
                android:background="#1565C0"
                android:gravity="center"
                android:layout_marginBottom="12dp" />

            <!-- ПРИМЕР 1: Простая сетка 3x3 с даными -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1️⃣ GridLayout 3×3:"
                android:textColor="#356B2C"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:rowCount="3"
                android:columnCount="3"
                android:layout_marginBottom="12dp">

                <!-- Заголовок -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Кол.1"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:background="#4CAF50"
                    android:padding="12dp"
                    android:layout_row="0"
                    android:layout_column="0"
                    android:layout_columnWeight="1"
                    android:layout_rowWeight="1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Кол.2"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:background="#4CAF50"
                    android:padding="12dp"
                    android:layout_row="0"
                    android:layout_column="1"
                    android:layout_columnWeight="1"
                    android:layout_rowWeight="1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Кол.3"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:background="#4CAF50"
                    android:padding="12dp"
                    android:layout_row="0"
                    android:layout_column="2"
                    android:layout_columnWeight="1"
                    android:layout_rowWeight="1" />

                <!-- Строка 1 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1-1"
                    android:textColor="#000000"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:background="#FFFFFF"
                    android:padding="12dp"
                    android:layout_row="1"
                    android:layout_column="0"
                    android:layout_columnWeight="1"
                    android:layout_rowWeight="1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1-2"
                    android:textColor="#000000"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:background="#E8F5E9"
                    android:padding="12dp"
                    android:layout_row="1"
                    android:layout_column="1"
                    android:layout_columnWeight="1"
                    android:layout_rowWeight="1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1-3"
                    android:textColor="#000000"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:background="#FFFFFF"
                    android:padding="12dp"
                    android:layout_row="1"
                    android:layout_column="2"
                    android:layout_columnWeight="1"
                    android:layout_rowWeight="1" />

                <!-- Строка 2 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2-1"
                    android:textColor="#000000"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:background="#E8F5E9"
                    android:padding="12dp"
                    android:layout_row="2"
                    android:layout_column="0"
                    android:layout_columnWeight="1"
                    android:layout_rowWeight="1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2-2"
                    android:textColor="#000000"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:background="#FFFFFF"
                    android:padding="12dp"
                    android:layout_row="2"
                    android:layout_column="1"
                    android:layout_columnWeight="1"
                    android:layout_rowWeight="1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2-3"
                    android:textColor="#000000"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:background="#E8F5E9"
                    android:padding="12dp"
                    android:layout_row="2"
                    android:layout_column="2"
                    android:layout_columnWeight="1"
                    android:layout_rowWeight="1" />
            </GridLayout>

            <!-- ПРИМЕР 2: Объединение ячеек (Span) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2️⃣ Объединение ячеек (columnSpan, rowSpan):"
                android:textColor="#356B2C"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:rowCount="4"
                android:columnCount="3"
                android:layout_marginBottom="12dp">

                <!-- Объединено 2 колонки -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4 ячейки (2×2)"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:background="#2196F3"
                    android:padding="16dp"
                    android:layout_row="0"
                    android:layout_column="0"
                    android:layout_columnSpan="2"
                    android:layout_rowSpan="2" />

                <!-- Обычная ячейка -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1 ячейка"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:background="#FF6F00"
                    android:padding="16dp"
                    android:layout_row="0"
                    android:layout_column="2" />

                <!-- Обычная ячейка -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1 ячейка"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:background="#D32F2F"
                    android:padding="16dp"
                    android:layout_row="1"
                    android:layout_column="2" />

                <!-- 3 ячейки в ширину -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3 ячейки в ширину"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:background="#7B1FA2"
                    android:padding="12dp"
                    android:layout_row="2"
                    android:layout_column="0"
                    android:layout_columnSpan="3" />

                <!-- 2 ячейки в высоту -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2\nв\nвысоту"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:background="#00897B"
                    android:padding="16dp"
                    android:layout_row="2"
                    android:layout_column="1"
                    android:layout_rowSpan="2" />

                <!-- Обычная ячейка -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:background="#558B2F"
                    android:padding="16dp"
                    android:layout_row="2"
                    android:layout_column="2" />

                <!-- Обычная ячейка -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:background="#004D40"
                    android:padding="16dp"
                    android:layout_row="3"
                    android:layout_column="2" />
            </GridLayout>

            <!-- ПРИМЕР 3: Объединение с весом (Weight) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3️⃣ GridLayout с весом (layoutWeight):"
                android:textColor="#356B2C"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:rowCount="2"
                android:columnCount="4"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:text="Weight 1"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:background="#4CAF50"
                    android:padding="8dp"
                    android:layout_row="0"
                    android:layout_column="0"
                    android:layout_columnWeight="1" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:text="Weight 1"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:background="#2196F3"
                    android:padding="8dp"
                    android:layout_row="0"
                    android:layout_column="1"
                    android:layout_columnWeight="1" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:text="Weight 1"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:background="#FF6F00"
                    android:padding="8dp"
                    android:layout_row="0"
                    android:layout_column="2"
                    android:layout_columnWeight="1" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:text="Weight 1"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:background="#D32F2F"
                    android:padding="8dp"
                    android:layout_row="0"
                    android:layout_column="3"
                    android:layout_columnWeight="1" />

                <!-- Вторая строка с разными весами -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:text="W:2"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:background="#7B1FA2"
                    android:padding="8dp"
                    android:layout_row="1"
                    android:layout_column="0"
                    android:layout_columnWeight="2" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:text="W:1"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:background="#00897B"
                    android:padding="8dp"
                    android:layout_row="1"
                    android:layout_column="2"
                    android:layout_columnWeight="1" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:text="W:1"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:background="#F57C00"
                    android:padding="8dp"
                    android:layout_row="1"
                    android:layout_column="3"
                    android:layout_columnWeight="1" />
            </GridLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="20dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
