<?xml version="1.0" encoding="utf-8"?>
<!--
LinearLayout с weight (вес элемента) и layout_gravity
Демонстрирует распределение пространства между элементами
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/linear_layout_weight"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp"
    tools:context=".MainActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📐 LinearLayout: Вес элемента (Weight)"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:padding="12dp"
        android:background="#1565C0"
        android:gravity="center"
        android:layout_marginBottom="12dp" />

    <!-- ПРИМЕР 1: Базовый вес (распределение пространства поровну) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:text="Weight 1"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:gravity="center"
            android:background="#4CAF50"
            android:layout_margin="4dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:text="Weight 1"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:gravity="center"
            android:background="#2196F3"
            android:layout_margin="4dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:text="Weight 1"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:gravity="center"
            android:background="#FF6F00"
            android:layout_margin="4dp" />
    </LinearLayout>

    <!-- ПРИМЕР 2: Разные веса (неравномерное распределение) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:text="Weight 1"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:gravity="center"
            android:background="#D32F2F"
            android:layout_margin="4dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="2"
            android:text="Weight 2"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:gravity="center"
            android:background="#7B1FA2"
            android:layout_margin="4dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="3"
            android:text="Weight 3"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:gravity="center"
            android:background="#00897B"
            android:layout_margin="4dp" />
    </LinearLayout>

    <!-- ПРИМЕР 3: layout_gravity (выравнивание элемента в контейнере) -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="layout_gravity (выравнивание в контейнере):"
        android:textColor="#356B2C"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:orientation="horizontal"
        android:background="#F0F0F0"
        android:layout_marginBottom="12dp">

        <!-- layout_gravity="start" - левый край -->
        <TextView
            android:layout_width="80dp"
            android:layout_height="60dp"
            android:text="start"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:gravity="center"
            android:background="#4CAF50"
            android:layout_gravity="start"
            android:layout_margin="4dp" />

        <!-- layout_gravity="center_vertical" - вертикальный центр -->
        <TextView
            android:layout_width="80dp"
            android:layout_height="60dp"
            android:text="center\nV"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:gravity="center"
            android:background="#2196F3"
            android:layout_gravity="center_vertical"
            android:layout_margin="4dp" />

        <!-- layout_gravity="end" - правый край -->
        <TextView
            android:layout_width="80dp"
            android:layout_height="60dp"
            android:text="end"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:gravity="center"
            android:background="#FF6F00"
            android:layout_gravity="end"
            android:layout_margin="4dp" />

        <!-- layout_gravity="bottom" - нижний край -->
        <TextView
            android:layout_width="80dp"
            android:layout_height="60dp"
            android:text="bottom"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:gravity="center"
            android:background="#D32F2F"
            android:layout_gravity="bottom"
            android:layout_margin="4dp" />
    </LinearLayout>

    <!-- ПРИМЕР 4: Вертикальная раскладка с весом -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Вертикальное распределение (weight):"
        android:textColor="#356B2C"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text="Weight 1 (1/6)"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:gravity="center"
            android:background="#4CAF50"
            android:layout_margin="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="2"
            android:text="Weight 2 (2/6 = 1/3)"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:gravity="center"
            android:background="#2196F3"
            android:layout_margin="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="3"
            android:text="Weight 3 (3/6 = 1/2)"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:gravity="center"
            android:background="#FF6F00"
            android:layout_margin="4dp" />
    </LinearLayout>

    <!-- ПРИМЕР 5: Смешанное использование weight и фиксированных размеров -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <!-- Фиксированный размер -->
        <TextView
            android:layout_width="80dp"
            android:layout_height="50dp"
            android:text="80dp"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:gravity="center"
            android:background="#D32F2F"
            android:layout_margin="4dp" />

        <!-- Занимает оставшееся место -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="Оставшееся место"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:gravity="center"
            android:background="#7B1FA2"
            android:layout_margin="4dp" />
    </LinearLayout>

</LinearLayout>
